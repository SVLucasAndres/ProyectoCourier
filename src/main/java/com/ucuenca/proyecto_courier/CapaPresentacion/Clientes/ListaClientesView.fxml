<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #ffffff;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Clientes.ListaClientesController">
   <children>

      <Label text="Gestión de Clientes" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>

      <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colCedula" prefWidth="75.0" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="200.0" text="Nombre Completo" />
            <TableColumn fx:id="colDireccion" prefWidth="200.0" text="Correo Electrónico" />
            <TableColumn fx:id="colTelefono" prefWidth="150.0" text="Teléfono" />
            <TableColumn fx:id="colAcciones" prefWidth="120.0" text="Mostrar Envíos" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

   </children>
</VBox>