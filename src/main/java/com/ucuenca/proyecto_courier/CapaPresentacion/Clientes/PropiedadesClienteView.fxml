<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Clientes.PropiedadesClienteController" prefWidth="700.0" prefHeight="500.0" style="-fx-padding: 20;">

    <VBox spacing="5.0" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-background-radius: 5; -fx-border-color: #cccccc;">
        <Label text="DETALLES DEL CLIENTE" style="-fx-font-weight: bold; -fx-font-size: 14;" />
        <GridPane hgap="10" vgap="5">
            <Label text="Cédula:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblCedula" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Dirección:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblDireccion" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblTelefono" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>
    </VBox>

    <Label text="Historial de Envíos Realizados" style="-fx-font-weight: bold; -fx-font-size: 13;" />
    <TableView fx:id="tablaEnvios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colIdEnvio" prefWidth="100.0" text="Código Envío" />
            <TableColumn fx:id="colDestinatario" prefWidth="180.0" text="Destinatario" />
            <TableColumn fx:id="colRapidez" prefWidth="100.0" text="Rapidez" />
            <TableColumn fx:id="colPago" prefWidth="120.0" text="M. Pago" />
        </columns>
    </TableView>

    <HBox alignment="TOP_RIGHT">
        <Button fx:id="btnVolver" text="Volver al Listado" onAction="#handleVolver" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;" />
    </HBox>
</VBox>
