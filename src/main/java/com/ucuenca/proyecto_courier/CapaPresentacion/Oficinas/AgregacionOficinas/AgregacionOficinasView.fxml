<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="550.0" prefWidth="600.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 25;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Oficinas.AgregacionOficinas.AgregacionOficinasController">
    <children>

        <VBox spacing="5.0">
            <children>
                <Label text="Registrar Nueva Oficina" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label text="Ingrese los datos requeridos. El código identificador se generará automáticamente." textFill="#7f8c8d" />
            </children>
        </VBox>

        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Código Autogenerado:" />
                        <TextField fx:id="txtIdOficina" disable="true" editable="false" prefWidth="150.0" style="-fx-background-color: #edf2f7; -fx-font-weight: bold; -fx-alignment: center;" text="OFI-XXXXXX" />
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="textoAlerta" text="" textFill="#8d2e31" style="-fx-font-weight: bold;" />
                    </children>
                </HBox>

                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Nombre / Sucursal: *" textFill="#34495e" />
                        <TextField fx:id="txtNombre" prefHeight="35.0" promptText="Ej: Sucursal El Ejido" style="-fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Dirección Exacta: *" textFill="#34495e" />
                        <TextField fx:id="txtDireccion" prefHeight="35.0" promptText="Ej: Av. Solano y Turi" style="-fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Teléfono: *" textFill="#34495e" />
                        <TextField fx:id="txtTelefono" prefHeight="35.0" promptText="Ej: 0999129323" style="-fx-background-radius: 5;" />
                    </children>
                </VBox>

            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#handleCancelar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />
                <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#handleGuardar" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Guardar Oficina" />
            </children>
        </HBox>

    </children>
</VBox>