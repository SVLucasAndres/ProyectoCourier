<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.MainLayoutController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="200.0" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 0 20 0 20;" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="imgLogo" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" />
                <Label text="Sistema de Gestión" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #34495e; -fx-padding: 20 10 20 10;" BorderPane.alignment="CENTER">
            <children>
                <Label text="MENÚ" textFill="#bdc3c7">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" left="10.0" />
                    </VBox.margin>
                </Label>
                <Button fx:id="btnInicio" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #1abc9c; -fx-text-fill: white;" text="Inicio" />
                <Button fx:id="btnClientes" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Clientes" />
                <Button fx:id="btnEnvios" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Envios" />
                <Button fx:id="btnPaquetes" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Paquetes" />
                <Button fx:id="btnOficinas" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Oficinas" />
                <Button fx:id="btnConfig" alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Configuración" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="15.0" style="-fx-padding: 20;" BorderPane.alignment="CENTER" fx:id="panelCentral">
            <children>
                <Label text="Listado de Clientes" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>
</BorderPane>
