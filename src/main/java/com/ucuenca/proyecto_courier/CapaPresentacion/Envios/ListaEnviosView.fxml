<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #ffffff;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Envios.ListaEnviosController">
    <children>

        <Label text="Gestión de Envios" textFill="#2c3e50" >
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <TableView fx:id="tablaClientes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIdEnvio" prefWidth="110.0" text="Código Envío" />
                <TableColumn fx:id="colDestinatario" prefWidth="180.0" text="ID Destinatario" />
                <TableColumn fx:id="colPaquetes" prefWidth="90.0" text="N°. Paquetes" />
                <TableColumn fx:id="colRapidez" prefWidth="110.0" text="Tipo Rapidez" />
                <TableColumn fx:id="colPago" prefWidth="110.0" text="Método Pago" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </children>
</VBox>