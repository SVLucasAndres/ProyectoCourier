<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: #ffffff;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Envios.ListaEnvios.ListaEnviosController">
    <children>
        <HBox nodeOrientation="LEFT_TO_RIGHT" stylesheets="/estilos.css">
            <Label text="Gestión de Envios" textFill="#2c3e50" >
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
            <Pane HBox.hgrow="ALWAYS"></Pane>

            <Button fx:id="btnGenerarEnvio" alignment="CENTER_RIGHT" mnemonicParsing="false" text="Generar Envio" styleClass="botonAgregar" onAction="#handleGenerarEnvio"/>
        </HBox>

        <TableView fx:id="tablaEnvios" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIdEnvio" prefWidth="110.0" text="Código Envío" />
                <TableColumn fx:id="colIdDestinatario" prefWidth="180.0" text="ID Destinatario" />
                <TableColumn fx:id="colPaquetes" prefWidth="90.0" text="N°. Paquetes" />
                <TableColumn fx:id="colRapidez" prefWidth="110.0" text="Tipo Rapidez" />
                <TableColumn fx:id="colPago" prefWidth="110.0" text="Método Pago" />
                <TableColumn fx:id="colAcciones" prefWidth="110.0" text="Acciones" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </children>
</VBox>