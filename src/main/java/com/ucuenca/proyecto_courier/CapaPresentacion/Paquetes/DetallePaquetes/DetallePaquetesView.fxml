<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="600.0" prefWidth="650.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-padding: 25;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.proyecto_courier.CapaPresentacion.Paquetes.DetallePaquetes.DetallePaquetesController">
    <children>

        <VBox spacing="5.0">
            <children>
                <Label text="Detalle del Paquete" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
            <children>

                <GridPane hgap="15.0" vgap="15.0"> <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                </columnConstraints>
                    <rowConstraints>
                        <RowConstraints vgrow="SOMETIMES" />
                        <RowConstraints vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Código de Paquete:" textFill="#34495e" />
                                <TextField fx:id="txtIdPaquete" editable="false" style="-fx-background-color: #edf2f7; -fx-font-weight: bold;" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Asegurado:" textFill="#34495e" />
                                <CheckBox fx:id="chkSeguro" disable="true" mnemonicParsing="false" style="-fx-padding: 5 0 0 0;" text="Posee seguro de mercadería" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Peso Registrado:" textFill="#34495e" />
                                <TextField fx:id="txtPeso" editable="false" style="-fx-background-color: #edf2f7;" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Valor Declarado:" textFill="#34495e" />
                                <TextField fx:id="txtValor" editable="false" style="-fx-background-color: #edf2f7;" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>
                <Separator prefWidth="200.0" />

                <StackPane alignment="TOP_LEFT">
                    <children>
                        <VBox fx:id="paneSobre" spacing="5.0" visible="false">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Tamaño del Sobre:" textFill="#34495e" />
                                <TextField fx:id="txtTamano" editable="false" prefWidth="200.0" style="-fx-background-color: #edf2f7;" />
                            </children>
                        </VBox>

                        <HBox fx:id="paneCaja" spacing="15.0" visible="false">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Alto:" textFill="#34495e" />
                                        <TextField fx:id="txtAlto" editable="false" style="-fx-background-color: #edf2f7;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Ancho:" textFill="#34495e" />
                                        <TextField fx:id="txtAncho" editable="false" style="-fx-background-color: #edf2f7;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Largo:" textFill="#34495e" />
                                        <TextField fx:id="txtLargo" editable="false" style="-fx-background-color: #edf2f7;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </StackPane>

                <Separator prefWidth="200.0" />

                <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Ruta Logística Asignada (Puntos de Control):" textFill="#34495e" />
                        <ListView fx:id="lstRutaOficinas" prefHeight="150.0" style="-fx-background-radius: 5;" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>

            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#handleVolver" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="Volver al Listado" />
            </children>
        </HBox>

    </children>
</VBox>
